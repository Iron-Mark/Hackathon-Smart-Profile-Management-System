# Local demo mode
# The restored showcase uses browser-local demo storage only.
VITE_DEMO_MODE=true

# Demo credentials:
# Faculty: faculty@umak.edu.ph / Faculty123
# Admin: admin@umak.edu.ph / Admin123

# Public showcase URL used by SEO metadata and static crawler files.
VITE_SITE_URL=https://iron-mark.github.io/Hackathon-Smart-Profile-Management-System/

# Optional Clerk showcase authentication
# If omitted, the seeded browser-local demo auth remains the only active path.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional OpenAI integration
# If omitted, the app uses deterministic demo/mock AI responses.
VITE_OPENAI_API_KEY=
